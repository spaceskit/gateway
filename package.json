{
  "name": "spaceskit-gateway",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "SPACESKIT_PORT=${SPACESKIT_PORT:-9320} SPACESKIT_GATEWAY_PROFILE=${SPACESKIT_GATEWAY_PROFILE:-embedded} SPACESKIT_MAIN_RESOURCE_ID=${SPACESKIT_MAIN_RESOURCE_ID:-resource:main} bun run packages/bootstrap/src/index.ts",
    "dev:embedded": "SPACESKIT_PORT=${SPACESKIT_PORT:-9320} SPACESKIT_GATEWAY_PROFILE=${SPACESKIT_GATEWAY_PROFILE:-embedded} SPACESKIT_MAIN_RESOURCE_ID=${SPACESKIT_MAIN_RESOURCE_ID:-resource:main} bun run packages/bootstrap/src/index.ts",
    "dev:external": "SPACESKIT_PORT=${SPACESKIT_PORT:-9321} SPACESKIT_GATEWAY_PROFILE=external SPACESKIT_MAIN_RESOURCE_ID=${SPACESKIT_MAIN_RESOURCE_ID:-resource:external} bun run packages/bootstrap/src/index.ts",
    "dev:external:strict:example": "SPACESKIT_SANDBOX_RUNTIME_MODULE=${SPACESKIT_SANDBOX_RUNTIME_MODULE:-./docs/examples/sandbox-runtime-module.mjs} SPACESKIT_PORT=${SPACESKIT_PORT:-9321} SPACESKIT_GATEWAY_PROFILE=external SPACESKIT_MAIN_RESOURCE_ID=${SPACESKIT_MAIN_RESOURCE_ID:-resource:external} bun run packages/bootstrap/src/index.ts",
    "dev:external:local": "SPACESKIT_ARCH_FREEZE_ENFORCED=false SPACESKIT_PORT=${SPACESKIT_PORT:-9321} SPACESKIT_GATEWAY_PROFILE=external SPACESKIT_MAIN_RESOURCE_ID=${SPACESKIT_MAIN_RESOURCE_ID:-resource:external} bun run packages/bootstrap/src/index.ts",
    "db:reset:all": "node scripts/reset-gateway-dbs.mjs",
    "db:reset:all:dry-run": "node scripts/reset-gateway-dbs.mjs --dry-run",
    "db:reset:all:force": "node scripts/reset-gateway-dbs.mjs --force",
    "build": "node ./scripts/workspace-build.mjs build",
    "typecheck": "node ./scripts/workspace-build.mjs typecheck",
    "typecheck:scripts": "tsc -p scripts/tsconfig.json --noEmit",
    "check:all": "bash scripts/check-all.sh",
    "contract-gate": "bun run scripts/verify-protocol-fixtures.ts && bun run scripts/verify-core-client-contract.ts",
    "test": "bun test",
    "docs:generate": "bun run ../dev-services/scripts/generate-docs.ts",
    "docs:check": "bun run ../dev-services/scripts/generate-docs.ts --check"
  },
  "devDependencies": {
    "@spaceskit/noise": "workspace:*",
    "@types/bun": "^1.3.9",
    "typescript": "^5.7.0"
  }
}
