# ============================================================================
# Spaceskit Gateway — Environment Variables
# ============================================================================
# Copy this file to .env and fill in the values.
# Variables marked [required] must be set for production use.
# Variables marked [optional] have sensible defaults shown after the "=".

# ----------------------------------------------------------------------------
# Server
# ----------------------------------------------------------------------------
# SPACESKIT_PORT=9320                            # [optional] HTTP/WS listen port
# SPACESKIT_HOST=127.0.0.1                       # [optional] Bind address
# SPACESKIT_LOG_LEVEL=info                       # [optional] trace | debug | info | warn | error
# SPACESKIT_LOG_FILE=                            # [optional] Path to write structured log file
# SPACESKIT_HEALTH_DEBUG=false                   # [optional] Expose detailed health-check info
# SPACESKIT_GATEWAY_PROFILE=                     # [optional] "embedded" | "external" (auto-detected from port)
# SPACESKIT_GENERATION=v2_2026_02_21             # [optional] Runtime generation tag

# ----------------------------------------------------------------------------
# Database
# ----------------------------------------------------------------------------
# SPACESKIT_DB_PATH=./gateway.db                 # [optional] SQLite database file path
# SPACESKIT_SPACES_ROOT=                         # [optional] Base root folder for per-space workspace folders

# ----------------------------------------------------------------------------
# Identity — Main space bootstrap
# ----------------------------------------------------------------------------
# SPACESKIT_MAIN_SPACE_ID=main-space             # [optional] Default space ID
# SPACESKIT_MAIN_SPACE_NAME=Embedded Main Space  # [optional] Display name for the default space
# SPACESKIT_MAIN_RESOURCE_ID=resource:main       # [optional] Resource identifier for this gateway
# SPACESKIT_MAIN_SPACE_GOAL=                     # [optional] Goal description for the main space
# SPACESKIT_MAIN_PROFILE_ID=main-profile         # [optional] Default profile ID
# SPACESKIT_MAIN_ORCHESTRATOR_PROFILE_ID=        # [optional] Orchestrator profile (defaults to MAIN_PROFILE_ID)
# SPACESKIT_MAIN_AGENT_ID=main-agent             # [optional] Default agent ID

# ----------------------------------------------------------------------------
# Execution Integrations
# ----------------------------------------------------------------------------
# SPACESKIT_MODEL_PROVIDER=                      # [optional] Default execution provider ID
# SPACESKIT_MODEL=                               # [optional] Default model ID
# SPACESKIT_API_KEY=                             # [optional] Default API key for the selected cloud provider
OPENROUTER_API_KEY=                              # [required for OpenRouter cloud API]
OPENAI_API_KEY=                                  # [required for OpenAI cloud API]
GROQ_API_KEY=                                    # [required for Groq cloud API]
TOGETHER_API_KEY=                                # [required for Together cloud API]
MISTRAL_API_KEY=                                 # [required for Mistral cloud API]
# OPENAI_BASE_URL=                               # [optional] Custom OpenAI-compatible base URL for `openai`
# LMSTUDIO_BASE_URL=                             # [optional] LM Studio base URL (default: http://127.0.0.1:1234/v1)
# OLLAMA_BASE_URL=                               # [optional] Ollama base URL (default: http://127.0.0.1:11434/v1)

# ----------------------------------------------------------------------------
# MCP (Model Context Protocol)
# ----------------------------------------------------------------------------
# MCP_ENDPOINT=                                  # [optional] Global MCP endpoint (http or stdio)
# SPACESKIT_MCP_SECRET_REF=                      # [optional] Secret ref for MCP authentication

# ----------------------------------------------------------------------------
# Memory providers
# ----------------------------------------------------------------------------
# MEM0_API_KEY=                                  # [optional] Mem0 memory provider API key
# LETTA_BASE_URL=                                # [optional] Letta server base URL
# LETTA_API_KEY=                                 # [optional] Letta API key

# ----------------------------------------------------------------------------
# Security & Authentication
# ----------------------------------------------------------------------------
SPACESKIT_SYNC_SHARED_SECRET=                    # [required for sync] Shared secret for peer sync auth
# SPACESKIT_SYNC_SECRET_<PEER_ID>=               # [optional] Per-peer override (PEER_ID uppercased, non-alnum → _)
# SPACESKIT_SECRET_REF_MASTER_KEY=               # [optional] Master key for encrypting provider secret refs
# SPACESKIT_REQUIRE_EXPLICIT_DEVICE_AUTH=false    # [optional] Require explicit device authorization
# SPACESKIT_REQUIRE_PREREGISTERED_DEVICE=false   # [optional] Require devices to be pre-registered

# ----------------------------------------------------------------------------
# Sync
# ----------------------------------------------------------------------------
# SPACESKIT_SYNC_LOCAL_PEER_ID=                  # [optional] Local peer ID (defaults to MAIN_RESOURCE_ID)
# SPACESKIT_SYNC_AUTO_PULL_ON_ANNOUNCE=false     # [optional] Auto-pull when a peer announces
# SPACESKIT_SYNC_AUTO_PULL_TARGET_SPACE_ID=      # [optional] Target space for auto-pull (defaults to MAIN_SPACE_ID)

# ----------------------------------------------------------------------------
# Sharing & Invites
# ----------------------------------------------------------------------------
# SPACESKIT_SHARE_INVITE_TTL_SECONDS=86400       # [optional] Invite link TTL in seconds (default: 24h)

# ----------------------------------------------------------------------------
# Orchestrator / Master mode
# ----------------------------------------------------------------------------
# SPACESKIT_MASTER_MODE_ENABLED=true             # [optional] Enable master orchestration mode
# SPACESKIT_MASTER_PLANNER_PROMPT_TEMPLATE=      # [optional] Custom planner prompt template
# SPACESKIT_GUEST_AGENT_PROMPT_TEMPLATE=         # [optional] Custom guest agent prompt template
# SPACESKIT_PEER_REVIEW_PROMPT_TEMPLATE=         # [optional] Custom peer review prompt template
# SPACESKIT_MASTER_SYNTHESIS_PROMPT_TEMPLATE=    # [optional] Custom synthesis prompt template
# SPACESKIT_GATEWAY_CAPABILITY_GRANTS=           # [optional] CSV list of capability grants

# ----------------------------------------------------------------------------
# Connectors
# ----------------------------------------------------------------------------
# SPACESKIT_ENABLE_WHATSAPP_CONNECTOR_FAMILY=    # [optional] Enable WhatsApp connector (default: true for external)
# SPACESKIT_ENABLE_DISCORD_CONNECTOR_FAMILY=     # [optional] Enable Discord connector (default: true for external)

# ----------------------------------------------------------------------------
# Voice
# ----------------------------------------------------------------------------
# SPACESKIT_ENABLE_SPEECH_MVP=false              # [optional] Enable speech session service
# SPACESKIT_VOICE_LOCK_ENABLED=                  # [optional] Enable voice usage limits
# SPACESKIT_VOICE_DEFAULT_SOURCE=managed          # [optional] "managed" | "byok" | "local" | "apple_speech"
# SPACESKIT_VOICE_MANAGED_PROVIDER_ID=           # [optional] Preferred managed voice provider
# SPACESKIT_VOICE_BYOK_PROVIDER_ID=              # [optional] BYOK voice provider ID
# SPACESKIT_VOICE_LOCAL_PROVIDER_ID=             # [optional] Local model voice provider ID
# SPACESKIT_VOICE_APPLE_PROVIDER_ID=             # [optional] Apple Speech provider ID
# SPACESKIT_VOICE_ALLOW_BYOK_FALLBACK=false      # [optional] Allow fallback to BYOK
# SPACESKIT_VOICE_ALLOW_LOCAL_FALLBACK=true      # [optional] Allow fallback to local models
# SPACESKIT_VOICE_ALLOW_APPLE_FALLBACK=true      # [optional] Allow fallback to Apple Speech
# SPACESKIT_VOICE_MANAGED_STT_SECONDS_LIMIT=     # [optional] Monthly managed STT seconds limit
# SPACESKIT_VOICE_MANAGED_TTS_CHARS_LIMIT=       # [optional] Monthly managed TTS characters limit
# SPACESKIT_VOICE_MANAGED_TTS_SECONDS_LIMIT=     # [optional] Monthly managed TTS seconds limit

# ----------------------------------------------------------------------------
# Resilience & Rate Limiting
# ----------------------------------------------------------------------------
# SPACESKIT_TRACING=true                         # [optional] Enable OpenTelemetry tracing (set "false" to disable)
# SPACESKIT_RESILIENCE=true                      # [optional] Enable resilience middleware (set "false" to disable)
# SPACESKIT_RATE_LIMIT=60                        # [optional] Requests per minute rate limit
# SPACESKIT_HEARTBEAT_INTERVAL_MS=30000          # [optional] WebSocket heartbeat interval in ms

# ----------------------------------------------------------------------------
# Scheduler
# ----------------------------------------------------------------------------
# SPACESKIT_SCHEDULER_TICK_MS=15000              # [optional] Scheduler tick interval in ms (min: 1000)

# ----------------------------------------------------------------------------
# Config hot-reload
# ----------------------------------------------------------------------------
# SPACESKIT_CONFIG_FILE=                         # [optional] Path to config JSON file for hot-reload
# SPACESKIT_CONFIG_POLL_MS=5000                  # [optional] Config file poll interval in ms

# ----------------------------------------------------------------------------
# Workspace logging
# ----------------------------------------------------------------------------
# SPACESKIT_WORKSPACE_LOG_DEBUG=false            # [optional] Include full payload bodies in workspace logs

# ----------------------------------------------------------------------------
# Legacy aliases (deprecated — use MAIN_ variants instead)
# ----------------------------------------------------------------------------
