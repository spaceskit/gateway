{
  "name": "@spaceskit/bootstrap",
  "version": "0.1.0",
  "type": "module",
  "description": "Bootstrap entry point for Spaceskit (Bun runtime)",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "spaceskit-gateway": "src/index.ts"
  },
  "scripts": {
    "build": "tsc",
    "dev": "bun run --watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@spaceskit/client": "file:../../../client-ts",
    "@spaceskit/contracts": "*",
    "@spaceskit/core": "*",
    "@spaceskit/gateway-core": "*",
    "@spaceskit/mcp-ai-sdk": "*",
    "@spaceskit/mcp-runtime": "*",
    "@spaceskit/observability": "*",
    "@spaceskit/persistence": "*",
    "@spaceskit/policy": "*",
    "@spaceskit/provider-runtime": "*",
    "@spaceskit/server": "*",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0",
    "typescript": "^6.0.2"
  }
}
